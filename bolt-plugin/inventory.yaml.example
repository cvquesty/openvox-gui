# ─── OpenVox GUI Dynamic Bolt Inventory ────────────────────────
#
# This inventory file reads ALL targets and groups from the OpenVox
# GUI's Node Classifier database. You never need to edit this file —
# manage nodes and groups in the GUI, and Bolt picks them up live.
#
# Install the openvox_enc plugin module:
#   cp -r /opt/openvox-gui/bolt-plugin/openvox_enc \
#         /etc/puppetlabs/bolt/modules/openvox_enc
#
# Then replace /etc/puppetlabs/bolt/inventory.yaml with this file.
# ────────────────────────────────────────────────────────────────

version: 2

config:
  transport: ssh
  ssh:
    host-key-check: false
    user: bolt
    private-key: /etc/puppetlabs/bolt/id_bolt

    # IMPORTANT: We deliberately do NOT set a global run-as / run-as-command here.
    #
    # Default behavior: every bolt invocation (whether from the GUI Orchestration
    # page or from a shell as the 'bolt' user on the controller) runs commands and
    # tasks as the SSH transport user ('bolt') on the target.
    #
    # Privilege escalation is opt-in per invocation:
    #   - GUI Run Command tab: the "Run privileged" checkbox (or the built-in
    #     heuristic for puppet agent / systemctl / package commands) causes the
    #     backend to prefix "sudo " to the command string. Bolt then executes
    #     `sudo <original>` on the target *as the bolt SSH user*, which exercises
    #     the bolt user's sudoers entry on the target.
    #   - Direct CLI: the operator types `sudo ...` themselves when needed
    #     (`bolt command run "sudo puppet agent -t" -t ovagent1`).
    #   - GUI Run Task / scripts / file ops: when escalation is needed the
    #     frontend sends run_as and the backend passes `--run-as root` to Bolt.
    #
    # This design makes CLI and GUI produce identical results for the same
    # command (e.g. `whoami` returns "bolt" from both surfaces by default).
    #
    # On the *targets*, the bolt user must have a sudoers entry that allows
    # the commands it will be asked to run as root (initially a broad
    # `bolt ALL=(ALL) NOPASSWD: ALL` is the practical choice because the
    # Orchestration ad-hoc command box accepts arbitrary operator input;
    # it can be tightened later). See docs/SUDOERS.md for the recommended
    # target sudoers + env_keep / !env_reset pattern so Puppet paths work
    # correctly under sudo.

groups:
  # Static group for the OpenVox server itself (local transport).
  # We explicitly set run-as: bolt so that ad-hoc commands default to the
  # 'bolt' user (whoami returns bolt). This matches the behavior for SSH
  # targets and the documented GUI default. Privilege escalation ("Run
  # privileged") is done by prefixing sudo in the command or --run-as.
  - name: puppetserver
    targets:
      - uri: puppet.example.com
        config:
          transport: local
          local:
            run-as: bolt

  # Dynamic groups from the ENC database — resolved live on every
  # Bolt invocation. Groups and nodes are managed in the GUI's
  # Node Classifier. No manual maintenance needed.
  - name: enc
    targets:
      - _plugin: openvox_enc
        api_url: 'https://localhost:4567'
